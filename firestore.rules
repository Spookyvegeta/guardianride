rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    match /users/{userId} {
      match /profile/main {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.id == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
        allow delete: if isExistingOwner(userId);
      }
      match /emergencyContacts/{contactId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }
      match /workSessions/{sessionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }
    }

    // Global incidents collection — writable by any signed-in user, readable by all signed-in
    match /incidents/{incidentId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow update: if isSignedIn(); // responders can update status
      allow delete: if false;
    }

    match /platforms/{platformId} {
      allow get, list: if true;
      allow write: if false;
    }
    match /accidentHeatmapData/{heatmapId} {
      allow get, list: if true;
      allow write: if false;
    }
  }
}
